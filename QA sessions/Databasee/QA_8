DELIMITER //

CREATE PROCEDURE TransferFunds(
    IN sender_id INT,
    IN receiver_id INT,
    IN amount DECIMAL(10,2)
)
BEGIN
    DECLARE current_balance DECIMAL(10,2);   -- store sender balance, DECLARE is used to create variables inside a stored procedure
    DECLARE sql_error INT DEFAULT 0;         -- error flag, 👉 created a variable + initial value

    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION --If any SQL error happens →don’t crash → set sql_error = 1 → continue execution
    SET sql_error = 1;                       -- set flag if any SQL error

    START TRANSACTION;                       -- TCL: begin transaction

    SELECT balance INTO current_balance  --👉 Stores data into a variable, not table
    FROM accounts
    WHERE account_id = sender_id
    FOR UPDATE;                              -- It locks the selected row so no one else can modify it during the transaction

    IF current_balance < amount THEN
        ROLLBACK;                            -- TCL: undo all changes
        SELECT 'Insufficient funds' AS Status;

    ELSE
        UPDATE accounts
        SET balance = balance - amount
        WHERE account_id = sender_id;        -- deduct (not permanent yet)

        UPDATE accounts
        SET balance = balance + amount
        WHERE account_id = receiver_id;      -- add (not permanent yet)

        IF sql_error = 1 THEN
            ROLLBACK;                        -- TCL: undo on error
            SELECT 'Transaction failed' AS Status;

        ELSE
            COMMIT;                          -- TCL: save permanently
            SELECT 'Transfer successful' AS Status;
        END IF;
    END IF;

END //

DELIMITER ;

concept:
WHY VARIABLES ARE USED
---------------------
current_balance → stores DB value to use in IF condition
                 (needed for balance check logic)

sql_error → flag to track if any SQL error occurred
            (since handler doesn’t stop execution)

Without current_balance → cannot compare balance
Without sql_error → may COMMIT even after error ❌
