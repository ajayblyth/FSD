-- =========================================================
-- TASK: Bank Transfer (TCL, ACID, Stored Procedure)
-- =========================================================

-- SCENARIO:
-- Write a MySQL Stored Procedure to transfer funds 
-- from one account to another.

-- REQUIREMENTS:
-- 1. Use TCL (START TRANSACTION, COMMIT, ROLLBACK)
-- 2. Ensure ACID properties:
--    - If sender has insufficient balance → rollback
--    - If any error occurs → rollback
--    - Otherwise → commit transaction
-- 3. Prevent race conditions (use row locking)

-- =========================================================
-- SOLUTION
-- =========================================================
DELIMITER //

CREATE PROCEDURE TransferFunds(
    IN sender_id INT,
    IN receiver_id INT,
    IN amount DECIMAL(10,2)
)
BEGIN
    DECLARE current_balance DECIMAL(10,2);
    DECLARE sql_error INT DEFAULT 0;

    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    SET sql_error = 1;

    START TRANSACTION;

    SELECT balance INTO current_balance
    FROM accounts
    WHERE account_id = sender_id
    FOR UPDATE;

    IF current_balance < amount THEN
        ROLLBACK;
        SELECT 'Insufficient funds' AS Status;

    ELSE
        UPDATE accounts
        SET balance = balance - amount
        WHERE account_id = sender_id;

        UPDATE accounts
        SET balance = balance + amount
        WHERE account_id = receiver_id;

        IF sql_error = 1 THEN
            ROLLBACK;
            SELECT 'Transaction failed' AS Status;

        ELSE
            COMMIT;
            SELECT 'Transfer successful' AS Status;
        END IF;
    END IF;

END //

DELIMITER ;

