DELIMITER $$
CREATE PROCEDURE bank_transfer( IN from_acc Int, IN to_acc INT,
 IN amt DECIMAL(10,2))
BEGIN

START TRANSACTION;

UPDATE accounts
SET balance = balance- amt
WHERE account_id = from_acc
AND balance >= amt ; -- if amount less than deducting amount

UPDATE accounts
SET balance = balance +amt
WHERE account_id = to_acc;

COMMIT;

END $$
DELIMITER ;

