=============================================================================
4. BASIC QUERIES
=============================================================================

-- all orders
SELECT * FROM orders;

-- join
SELECT c.name, o.product_name
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id;


=============================================================================
5. CASE + AGGREGATION QUERIES
=============================================================================

-- product category
SELECT product_name, amount,
CASE
    WHEN amount >= 20000 THEN 'High'
    ELSE 'Low'
END AS category
FROM orders;


-- customer spending category
SELECT c.name, SUM(o.amount) AS total_spent,
CASE
    WHEN SUM(o.amount) >= 100000 THEN 'High Spender'
    ELSE 'Low Spender'
END AS category
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY c.name;


=============================================================================
6. ADVANCED FILTERING
=============================================================================

-- July orders
SELECT DISTINCT c.customer_id, c.name
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
WHERE o.order_date >= '2023-07-01'
AND o.order_date < '2023-08-01';


-- no orders in last 7 days
SELECT c.name
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
AND o.order_date >= NOW() - INTERVAL 7 DAY
WHERE o.order_id IS NULL;


