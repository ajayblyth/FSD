=============================================================================
8. WINDOW FUNCTIONS (IMPORTANT)
=============================================================================

-- row number
SELECT *,
ROW_NUMBER() OVER(ORDER BY order_date) AS row_num
FROM orders;


-- dense rank
SELECT *,
DENSE_RANK() OVER(ORDER BY amount) AS rnk
FROM orders;


-- max amount
SELECT *,
MAX(amount) OVER() AS max_amount
FROM orders;


-- min per category
SELECT *,
MIN(amount) OVER(PARTITION BY product_category) AS min_amount
FROM orders;


-- difference from max
SELECT *,
(MAX(amount) OVER() - amount) AS diff
FROM orders;


-- previous order
SELECT *,
LAG(amount) OVER(PARTITION BY customer_id ORDER BY order_date)
AS prev_amount
FROM orders;


-- first order per customer
SELECT * FROM (
    SELECT *,
    ROW_NUMBER() OVER(PARTITION BY customer_id ORDER BY order_date) AS rn
    FROM orders
) t
WHERE rn = 1;


-- top 2 per category
SELECT * FROM (
    SELECT *,
    ROW_NUMBER() OVER(PARTITION BY product_category ORDER BY amount DESC) AS rn
    FROM orders
) t
WHERE rn <= 2;


-- percentage contribution
SELECT *,
ROUND(100 * amount / SUM(amount) OVER(PARTITION BY product_category), 2)
AS percent_contribution
FROM orders;

